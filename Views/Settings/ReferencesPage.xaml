<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VirtmaAi.ViewModels.Settings"
             xmlns:entities="clr-namespace:VirtmaAi.Models.Entities"
             x:Class="VirtmaAi.Views.Settings.ReferencesPage"
             x:DataType="vm:ReferencesViewModel"
             Title="References"
             BackgroundColor="{StaticResource SurfaceDark}">

    <Grid ColumnDefinitions="300,*" Padding="0">
        <Grid Grid.Column="0" BackgroundColor="{StaticResource SurfaceDarkAlt}" RowDefinitions="Auto,*">
            <VerticalStackLayout Grid.Row="0" Padding="12" Spacing="8">
                <Label Text="References" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                <Label Text="Durable knowledge the AI can recall" TextColor="{StaticResource Gray400}" FontSize="11"/>
                <Button Text="+ New reference" Command="{Binding NewCommand}" BackgroundColor="{StaticResource Accent}" TextColor="White"/>
            </VerticalStackLayout>
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding All}"
                            SelectedItem="{Binding Selected, Mode=TwoWay}"
                            SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="entities:Reference">
                        <VerticalStackLayout Padding="12,10">
                            <Label Text="{Binding Title}" TextColor="White"/>
                            <Label Text="{Binding SourceType}" TextColor="{StaticResource Gray400}" FontSize="10"/>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="16" Spacing="8">
                <Label Text="Title" TextColor="{StaticResource Gray300}" FontSize="11"/>
                <Entry Text="{Binding EditorTitle, Mode=TwoWay}" TextColor="White"/>

                <Label Text="Triggers (JSON array or comma-separated)" TextColor="{StaticResource Gray300}" FontSize="11"/>
                <Entry Text="{Binding EditorTriggers, Mode=TwoWay}"
                       TextColor="White"
                       Placeholder="[&quot;database schema&quot;, &quot;snake_case&quot;]"
                       PlaceholderColor="{StaticResource Gray500}"/>

                <Label Text="Source type" TextColor="{StaticResource Gray300}" FontSize="11"/>
                <Picker ItemsSource="{Binding SourceTypes}"
                        SelectedItem="{Binding EditorSourceType, Mode=TwoWay}"
                        TextColor="White"/>

                <Label Text="{Binding SourceValueLabel}" TextColor="{StaticResource Gray300}" FontSize="11"/>

                <!-- File source: read-only path display + Browse button -->
                <Grid IsVisible="{Binding IsFileSource}"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                    <Entry Grid.Column="0"
                           Text="{Binding EditorSourceValue, Mode=TwoWay}"
                           TextColor="White"
                           Placeholder="{Binding SourceValuePlaceholder}"
                           PlaceholderColor="{StaticResource Gray500}"
                           IsReadOnly="True"/>
                    <Button Grid.Column="1"
                            Text="Browse…"
                            Command="{Binding BrowseFileCommand}"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="White"/>
                </Grid>

                <!-- URL source: single-line entry -->
                <Entry IsVisible="{Binding IsUrlSource}"
                       Text="{Binding EditorSourceValue, Mode=TwoWay}"
                       TextColor="White"
                       Placeholder="{Binding SourceValuePlaceholder}"
                       PlaceholderColor="{StaticResource Gray500}"
                       Keyboard="Url"/>

                <!-- Text source: multi-line editor -->
                <Editor IsVisible="{Binding IsTextSource}"
                        Text="{Binding EditorSourceValue, Mode=TwoWay}"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="180"
                        MaximumHeightRequest="500"
                        TextColor="White"
                        Placeholder="{Binding SourceValuePlaceholder}"
                        PlaceholderColor="{StaticResource Gray500}"
                        BackgroundColor="{StaticResource SurfaceDarkAlt}"/>

                <Label Text="Applies to (optional — e.g. a project name)" TextColor="{StaticResource Gray300}" FontSize="11"/>
                <Entry Text="{Binding EditorAppliesTo, Mode=TwoWay}"
                       TextColor="White"
                       Placeholder="Leave blank to apply globally"
                       PlaceholderColor="{StaticResource Gray500}"/>

                <HorizontalStackLayout Spacing="8" Margin="0,8,0,0">
                    <Button Text="Save" Command="{Binding SaveCommand}" BackgroundColor="{StaticResource Accent}" TextColor="White"/>
                    <Button Text="Delete" Command="{Binding DeleteCommand}" BackgroundColor="{StaticResource AccentInteractive}" TextColor="White"/>
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Margin="0,8"/>

                <Label Text="Test trigger matching" TextColor="{StaticResource Gray300}" FontSize="11"/>
                <Editor Text="{Binding MatchProbe, Mode=TwoWay}"
                        HeightRequest="60"
                        TextColor="White"
                        BackgroundColor="{StaticResource SurfaceDarkAlt}"
                        Placeholder="simulate a user message..."
                        PlaceholderColor="{StaticResource Gray500}"/>
                <Button Text="Probe matches"
                        Command="{Binding ProbeCommand}"
                        BackgroundColor="{StaticResource Accent}"
                        TextColor="White"
                        HorizontalOptions="Start"/>
                <Editor Text="{Binding MatchResults, Mode=OneWay}"
                        IsReadOnly="True"
                        HeightRequest="120"
                        BackgroundColor="{StaticResource SurfaceDarkAlt}"
                        TextColor="{StaticResource Gray300}"/>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="{StaticResource AccentInteractive}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
