<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VirtmaAi.ViewModels.Settings"
             xmlns:ent="clr-namespace:VirtmaAi.Models.Entities"
             x:Class="VirtmaAi.Views.Settings.AiRulesPage"
             x:DataType="vm:AiRulesViewModel"
             Title="AI Rules"
             BackgroundColor="{StaticResource SurfaceDark}">
    <Grid ColumnDefinitions="320,*" Padding="0">
        <!-- Sidebar: rules list -->
        <Grid Grid.Column="0"
              BackgroundColor="{StaticResource SurfaceDarkAlt}"
              RowDefinitions="Auto,Auto,*">
            <VerticalStackLayout Grid.Row="0" Padding="16" Spacing="6">
                <Label Text="AI rules"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"/>
                <Label Text="Every model follows these on every operation. Toggle a rule off to suspend it."
                       FontSize="11"
                       TextColor="{StaticResource Gray400}"
                       LineBreakMode="WordWrap"/>
            </VerticalStackLayout>

            <Button Grid.Row="1"
                    Text="+ New rule"
                    Margin="16,0"
                    Command="{Binding NewCommand}"
                    BackgroundColor="{StaticResource Accent}"
                    TextColor="White"/>

            <CollectionView Grid.Row="2"
                            x:Name="RulesList"
                            ItemsSource="{Binding Rules}"
                            SelectedItem="{Binding Selected, Mode=TwoWay}"
                            Margin="0,8,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="ent:AiRule">
                        <Grid Padding="14,8" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding Title}"
                                       TextColor="White"
                                       FontSize="13"
                                       LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding Body}"
                                       TextColor="{StaticResource Gray400}"
                                       FontSize="10"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding Enabled, Mode=TwoWay}"
                                    OnColor="{StaticResource Accent}"
                                    Toggled="OnRuleToggled"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- Editor / settings -->
        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="20" Spacing="14">
                <Label Text="Edit rule"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="White"/>

                <Label Text="Title"
                       TextColor="{StaticResource Gray300}"
                       FontSize="11"/>
                <Entry Text="{Binding EditorTitle, Mode=TwoWay}"
                       TextColor="White"
                       BackgroundColor="{StaticResource SurfaceDarkAlt}"
                       PlaceholderColor="{StaticResource Gray500}"
                       Placeholder="Short label, e.g. 'Always confirm destructive actions'"/>

                <Label Text="Rule body — what the AI must do or avoid"
                       TextColor="{StaticResource Gray300}"
                       FontSize="11"/>
                <Editor Text="{Binding EditorBody, Mode=TwoWay}"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="120"
                        TextColor="White"
                        BackgroundColor="{StaticResource SurfaceDarkAlt}"
                        PlaceholderColor="{StaticResource Gray500}"
                        Placeholder="Plain text. Will be prepended to every system prompt."/>

                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Priority (higher = earlier in prompt)"
                               TextColor="{StaticResource Gray300}"
                               FontSize="11"/>
                        <Entry Text="{Binding EditorPriority, Mode=TwoWay}"
                               Keyboard="Numeric"
                               TextColor="White"
                               BackgroundColor="{StaticResource SurfaceDarkAlt}"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="End">
                        <Label Text="Enabled"
                               TextColor="{StaticResource Gray300}"
                               FontSize="11"/>
                        <Switch IsToggled="{Binding EditorEnabled, Mode=TwoWay}"
                                OnColor="{StaticResource Accent}"/>
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="Save"
                            Command="{Binding SaveCommand}"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="White"/>
                    <Button Grid.Column="1"
                            Text="Delete"
                            Command="{Binding DeleteCommand}"
                            BackgroundColor="{StaticResource AccentInteractive}"
                            TextColor="White"/>
                </Grid>

                <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Margin="0,12"/>

                <!-- Global preferences -->
                <Label Text="Global AI preferences"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="White"/>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Show 'thinking' in chat"
                               TextColor="White"
                               FontSize="13"/>
                        <Label Text="When enabled, models that emit thinking tokens (like Claude or qwen3) will surface their reasoning in a collapsible section under the response."
                               TextColor="{StaticResource Gray400}"
                               FontSize="11"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding ShowThinking, Mode=TwoWay}"
                            OnColor="{StaticResource Accent}"
                            VerticalOptions="Center"/>
                </Grid>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Allow AI to modify VirtmaAi"
                               TextColor="White"
                               FontSize="13"/>
                        <Label Text="Lets the AI edit VirtmaAi's own source via the app-selfmodify plugin. Off by default."
                               TextColor="{StaticResource Gray400}"
                               FontSize="11"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding AllowSelfModify, Mode=TwoWay}"
                            OnColor="{StaticResource Accent}"
                            VerticalOptions="Center"/>
                </Grid>

                <Label Text="VirtmaAi source root (only used when self-modify is enabled)"
                       TextColor="{StaticResource Gray300}"
                       FontSize="11"/>
                <Entry Text="{Binding SelfModifyAppRoot, Mode=TwoWay}"
                       TextColor="White"
                       BackgroundColor="{StaticResource SurfaceDarkAlt}"
                       PlaceholderColor="{StaticResource Gray500}"
                       Placeholder="e.g. E:\Files\Programming\Projects\VirtmaAi\VirtmaAi"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
