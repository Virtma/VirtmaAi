<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VirtmaAi.ViewModels.Plugins"
             xmlns:entities="clr-namespace:VirtmaAi.Models.Entities"
             x:Class="VirtmaAi.Views.Plugins.PluginsListPage"
             x:DataType="vm:PluginsViewModel"
             Title="Plugins"
             BackgroundColor="{StaticResource SurfaceDark}">

    <Grid ColumnDefinitions="300,*" Padding="0">
        <Grid Grid.Column="0" BackgroundColor="{StaticResource SurfaceDarkAlt}" RowDefinitions="Auto,Auto,*,Auto,Auto">
            <VerticalStackLayout Grid.Row="0" Padding="12" Spacing="8">
                <Label Text="Plugins" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                <Button Text="+ New plugin" Command="{Binding NewCommand}" BackgroundColor="{StaticResource Accent}" TextColor="White"/>
            </VerticalStackLayout>
            <Label Grid.Row="1" Padding="12,8,12,4" Text="User plugins" TextColor="{StaticResource Gray400}" FontSize="11"/>
            <CollectionView Grid.Row="2"
                            ItemsSource="{Binding All}"
                            SelectedItem="{Binding Selected, Mode=TwoWay}"
                            SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="entities:Plugin">
                        <VerticalStackLayout Padding="12,10">
                            <Label Text="{Binding Name}" TextColor="White"/>
                            <Label Text="{Binding ExecutablePath}" TextColor="{StaticResource Gray400}" FontSize="10" LineBreakMode="TailTruncation" MaxLines="1"/>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Label Grid.Row="3" Padding="12,8,12,4" Text="Built-in" TextColor="{StaticResource Gray400}" FontSize="11"/>
            <CollectionView Grid.Row="4"
                            ItemsSource="{Binding BuiltIn}"
                            SelectionMode="None"
                            HeightRequest="160">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:BuiltInPluginRow">
                        <VerticalStackLayout Padding="12,8">
                            <Label Text="{Binding Name}" TextColor="White"/>
                            <Label Text="{Binding Description}" TextColor="{StaticResource Gray400}" FontSize="10"/>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <ScrollView Grid.Column="1">
            <VerticalStackLayout Padding="16" Spacing="8">
                <Label Text="Name" TextColor="{StaticResource Gray300}" FontSize="11"/>
                <Entry Text="{Binding EditorName, Mode=TwoWay}" TextColor="White"/>

                <Label Text="Triggers (JSON array of strings)" TextColor="{StaticResource Gray300}" FontSize="11"/>
                <Entry Text="{Binding EditorTriggers, Mode=TwoWay}" TextColor="White" Placeholder="[&quot;take a screenshot&quot;]"/>

                <Label Text="Instructions" TextColor="{StaticResource Gray300}" FontSize="11"/>
                <Editor Text="{Binding EditorInstructions, Mode=TwoWay}" HeightRequest="120" TextColor="White" BackgroundColor="{StaticResource SurfaceDarkAlt}"/>

                <Label Text="Executable path" TextColor="{StaticResource Gray300}" FontSize="11"/>
                <Entry Text="{Binding EditorExePath, Mode=TwoWay}" TextColor="White" Placeholder="C:\Windows\System32\notepad.exe"/>

                <Label Text="Arguments template — {input} is replaced with chat input" TextColor="{StaticResource Gray300}" FontSize="11"/>
                <Entry Text="{Binding EditorArgsTemplate, Mode=TwoWay}" TextColor="White" Placeholder="--flag {input}"/>

                <HorizontalStackLayout Spacing="8">
                    <Button Text="Save" Command="{Binding SaveCommand}" BackgroundColor="{StaticResource Accent}" TextColor="White"/>
                    <Button Text="Delete" Command="{Binding DeleteCommand}" BackgroundColor="{StaticResource AccentInteractive}" TextColor="White"/>
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Margin="0,8"/>

                <Label Text="Test input" TextColor="{StaticResource Gray300}" FontSize="11"/>
                <Editor Text="{Binding TestInput, Mode=TwoWay}" HeightRequest="80" TextColor="White" BackgroundColor="{StaticResource SurfaceDarkAlt}"/>
                <Button Text="Run plugin" Command="{Binding TestCommand}" BackgroundColor="{StaticResource Accent}" TextColor="White" HorizontalOptions="Start"/>
                <Label Text="Output" TextColor="{StaticResource Gray300}" FontSize="11"/>
                <Editor Text="{Binding TestOutput, Mode=OneWay}" IsReadOnly="True" HeightRequest="180" BackgroundColor="{StaticResource SurfaceDarkAlt}" TextColor="{StaticResource Gray300}"/>

                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource AccentInteractive}" IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}"/>

                <!-- ── Built-in plugin settings ──────────────────────────────── -->
                <BoxView HeightRequest="1" Color="{StaticResource Gray600}" Margin="0,16,0,8"/>

                <Label Text="Built-in plugin settings"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="White"/>

                <!-- Web Search timeout -->
                <Label Text="Web Search — request timeout"
                       TextColor="{StaticResource Gray300}"
                       FontSize="11"
                       Margin="0,8,0,0"/>
                <Label TextColor="{StaticResource Gray400}" FontSize="11">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="How long to wait for DuckDuckGo / Google / Bing before giving up."/>
                            <Span Text="&#10;"/>
                            <Span Text="Set to " TextColor="{StaticResource Gray400}"/>
                            <Span Text="0" FontAttributes="Bold" TextColor="White"/>
                            <Span Text=" to disable the timeout entirely (the Stop button remains the only way to cancel)." TextColor="{StaticResource Gray400}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <HorizontalStackLayout Spacing="10" Margin="0,6,0,0">
                    <Entry Text="{Binding WebSearchTimeoutText, Mode=TwoWay}"
                           Keyboard="Numeric"
                           WidthRequest="90"
                           TextColor="White"
                           BackgroundColor="{StaticResource SurfaceDarkAlt}"
                           ReturnCommand="{Binding SaveWebSearchSettingsCommand}"/>
                    <Label Text="seconds  (0 = no timeout)"
                           TextColor="{StaticResource Gray400}"
                           FontSize="12"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Button Text="Save timeout"
                        Command="{Binding SaveWebSearchSettingsCommand}"
                        BackgroundColor="{StaticResource Accent}"
                        TextColor="White"
                        HorizontalOptions="Start"
                        Margin="0,6,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
